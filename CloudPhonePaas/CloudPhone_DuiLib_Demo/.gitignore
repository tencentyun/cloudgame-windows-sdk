# =============================================================================
# CMake 构建产物
# =============================================================================
build/
out/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/

# =============================================================================
# vcpkg 目录不入库（由 build.ps1 自动 clone/初始化）
# =============================================================================
vcpkg/
vcpkg_installed/

# =============================================================================
# Visual Studio / MSVC 编译产物
# =============================================================================
# 编译中间文件
*.obj
*.pch
*.ilk
*.exp
*.map
*.idb
*.ipdb
*.iobj
*.pgc
*.pgd
*.pgo
*.VC.db
*.VC.opendb

# 链接产物
*.exe
*.dll
*.lib
*.pdb
*.sys

# VS 项目生成文件（CMake 生成的，不需要入库）
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
*.suo
*.sdf
*.opensdf
*.cachefile
*.psess
*.vsp
*.vspx
*.sap

# VS 用户设置和缓存
.vs/
*.user
*.userosscache
*.sln.docstates
.vscode/launch.json

# =============================================================================
# Windows 系统文件
# =============================================================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# =============================================================================
# macOS 系统文件（跨平台开发时产生）
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# =============================================================================
# 日志与临时文件
# =============================================================================
*.log
*.tmp
*.temp
*.bak
*.swp
*.orig
*~

# vcpkg 安装日志
vcpkg-manifest-install.log

# =============================================================================
# 截图 / 用户生成的临时图片（build 目录下的截图）
# =============================================================================
*.png
*.jpg
*.jpeg

# 但保留 skin/ 目录下的图片资源（取消上面对 skin 的影响）
!skin/**/*.png
!skin/**/*.jpg
!skin/**/*.jpeg
!skin/**/*.bmp
!skin/**/*.gif

# =============================================================================
# IDE / 编辑器
# =============================================================================
.idea/
*.iml
*.iws
*.ipr
.clangd/
.clang-tidy-cache/
compile_commands.json

# =============================================================================
# 敏感配置（如有 key/token 的本地配置文件）
# =============================================================================
config.local.json
*.secret
*.key
