<?xml version="1.0" encoding="UTF-8"?>
<Window size="420,360" caption="0,0,0,35" roundcorner="0,0">
    <Font id="0" name="Microsoft YaHei" size="12" default="true" />
    <Font id="1" name="Microsoft YaHei" size="14" bold="true" />

    <VerticalLayout bkcolor="#FFFFFFFF">
        <!-- Title bar -->
        <HorizontalLayout height="35" bkcolor="#FF2D8CF0">
            <Label name="lbl_title" text="修改传感器" font="1" textcolor="#FFFFFFFF" padding="10,0,0,0" />
            <Control />
        </HorizontalLayout>

        <!-- Content -->
        <VerticalLayout padding="20,12,20,12">
            <Label text="传感器类型:" font="0" textcolor="#FF333333" height="20" />
            <Combo name="combo_type" height="30" bordersize="1" bordercolor="#FFCCCCCC"
                   textpadding="8,4,8,4" font="0">
                <ListLabelElement text="accelerometer" />
                <ListLabelElement text="gyroscope" />
                <ListLabelElement text="significant_motion" />
                <ListLabelElement text="step_counter" />
                <ListLabelElement text="step_detector" />
                <ListLabelElement text="pressure" />
                <ListLabelElement text="proximity" />
            </Combo>
            <Control height="6" />
            <Label text="X 值:" font="0" textcolor="#FF333333" height="20" />
            <Edit name="edit_x" height="30" text="0.0"
                  bordersize="1" bordercolor="#FFCCCCCC"
                  textpadding="8,4,8,4" font="0" />
            <Control height="4" />
            <Label text="Y 值:" font="0" textcolor="#FF333333" height="20" />
            <Edit name="edit_y" height="30" text="0.0"
                  bordersize="1" bordercolor="#FFCCCCCC"
                  textpadding="8,4,8,4" font="0" />
            <Control height="4" />
            <Label text="Z 值:" font="0" textcolor="#FF333333" height="20" />
            <Edit name="edit_z" height="30" text="0.0"
                  bordersize="1" bordercolor="#FFCCCCCC"
                  textpadding="8,4,8,4" font="0" />
            <Control height="4" />
            <Label text="精度 (Accuracy):" font="0" textcolor="#FF333333" height="20" />
            <Edit name="edit_accuracy" height="30" text="3"
                  bordersize="1" bordercolor="#FFCCCCCC"
                  textpadding="8,4,8,4" font="0" />
            <Control />

            <!-- Buttons -->
            <HorizontalLayout height="36">
                <Control />
                <Button name="btn_ok" width="80" height="32" text="确定"
                        font="0" textcolor="#FFFFFFFF"
                        bkcolor="#FF2D8CF0" hotbkcolor="#FF5CADFF"
                        pushedbkcolor="#FF1A6FD4" borderround="4,4" />
                <Control width="10" />
                <Button name="btn_cancel" width="80" height="32" text="取消"
                        font="0" textcolor="#FF333333"
                        bkcolor="#FFE8E8E8" hotbkcolor="#FFDDDDDD"
                        pushedbkcolor="#FFCCCCCC" borderround="4,4" />
                <Control />
            </HorizontalLayout>
        </VerticalLayout>
    </VerticalLayout>
</Window>
