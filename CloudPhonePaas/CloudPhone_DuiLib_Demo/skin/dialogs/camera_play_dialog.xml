<?xml version="1.0" encoding="UTF-8"?>
<Window size="400,250" caption="0,0,0,35" roundcorner="0,0">
    <Font id="0" name="Microsoft YaHei" size="12" default="true" />
    <Font id="1" name="Microsoft YaHei" size="14" bold="true" />

    <VerticalLayout bkcolor="#FFFFFFFF">
        <!-- Title bar -->
        <HorizontalLayout height="35" bkcolor="#FF2D8CF0">
            <Label name="lbl_title" text="摄像头媒体播放" font="1" textcolor="#FFFFFFFF" padding="10,0,0,0" />
            <Control />
        </HorizontalLayout>

        <!-- Content -->
        <VerticalLayout padding="20,15,20,15">
            <Label text="文件路径 (FilePath):" font="0" textcolor="#FF333333" height="20" />
            <Edit name="edit_filepath" height="32" tiptext="/sdcard/video.mp4"
                  bordersize="1" bordercolor="#FFCCCCCC"
                  textpadding="8,4,8,4" font="0" />
            <Control height="8" />
            <Label text="循环次数 (Loops, -1=无限):" font="0" textcolor="#FF333333" height="20" />
            <Edit name="edit_loops" height="32" text="1"
                  bordersize="1" bordercolor="#FFCCCCCC"
                  textpadding="8,4,8,4" font="0" />
            <Control />

            <!-- Buttons -->
            <HorizontalLayout height="36">
                <Control />
                <Button name="btn_ok" width="80" height="32" text="确定"
                        font="0" textcolor="#FFFFFFFF"
                        bkcolor="#FF2D8CF0" hotbkcolor="#FF5CADFF"
                        pushedbkcolor="#FF1A6FD4" borderround="4,4" />
                <Control width="10" />
                <Button name="btn_cancel" width="80" height="32" text="取消"
                        font="0" textcolor="#FF333333"
                        bkcolor="#FFE8E8E8" hotbkcolor="#FFDDDDDD"
                        pushedbkcolor="#FFCCCCCC" borderround="4,4" />
                <Control />
            </HorizontalLayout>
        </VerticalLayout>
    </VerticalLayout>
</Window>
