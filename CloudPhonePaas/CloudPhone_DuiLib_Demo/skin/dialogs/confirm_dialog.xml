        <HorizontalLayout height="35" bkcolor="#FF2D8CF0">
            <Label name="lbl_title" text="确认" font="1" textcolor="#FFFFFFFF" padding="10,0,0,0" />
            <Control />
        </HorizontalLayout>

        <!-- Content -->
        <VerticalLayout padding="20,15,20,15">
            <Label name="lbl_message" text="" font="0" textcolor="#FF333333"
